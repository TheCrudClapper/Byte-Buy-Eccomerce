<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:dialogHost="using:DialogHostAvalonia"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:ByteBuy.UI.ViewModels.Dialogs"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="1000"
			 x:Class="ByteBuy.UI.OfferDialogView"
			 x:DataType="vm:OfferDialogViewModel">

	<UserControl.Styles>
		<StyleInclude Source="../../Styles/EmployeeStyles.axaml" />
	</UserControl.Styles>

	<Border CornerRadius="2"
			BorderThickness="2"
			Background="{DynamicResource CardBackgroundBrush}"
			BorderBrush="{DynamicResource ButtonGradient}"
			MinHeight="300"
			MinWidth="500">
		<ScrollViewer>
			<Grid RowDefinitions="30,*,*">

				<!-- Title bar -->
				<Border Grid.Row="0"
						Background="{DynamicResource ButtonGradient}"
						Height="30"
						VerticalAlignment="Top">
					<TextBlock Text="{Binding DialogTitle}"
							   Classes="dialogTitle" />
				</Border>

				<!-- Form Fields -->
				<StackPanel Margin="20"
							Spacing="10"
							Grid.Row="1">

					<!-- Offer type -->
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" IsVisible="{Binding !IsEditMode}">
						<TextBlock Classes="textBoxLabel"
								   Text="Sale Offer"
								   VerticalAlignment="Center"
								   Margin="0,0,5,0"/>
						<CheckBox  HorizontalAlignment="Right"
								   Command="{Binding ChangeOfferTypeCommand}" />
					</StackPanel>


					<!-- Selected item -->
					<TextBlock Text="Selected Stock Item"
							   IsVisible="{Binding !IsEditMode}"
							   Classes="textBoxLabel"
							   HorizontalAlignment="Stretch" />
					<TextBox IsEnabled="False"
							 IsVisible="{Binding !IsEditMode}"
							 Text="{Binding SelectedItem.Name}"
							 TextWrapping="Wrap" />

					<!-- Units -->
					<StackPanel IsVisible="{Binding !IsEditMode}" Spacing="10">
						<TextBlock Text="Quantity"
								   Classes="textBoxLabel" />
						<NumericUpDown Value="{Binding Quantity}"
									   Watermark="Enter avaliable quantity for rental"
									   FormatString="0"
									   Minimum="1" />
					</StackPanel>


					<Grid ColumnDefinitions="31*, 2*, 69*" IsVisible="{Binding IsEditMode}">
						<StackPanel Grid.Column="0" Spacing="10">
							<TextBlock Text="Current quantity"
									   Classes="textBoxLabel"
									   HorizontalAlignment="Stretch" />
							<TextBox IsEnabled="False"
									 Text="{Binding CurrentAvaliableQuantity}"
									 TextWrapping="Wrap" />
						</StackPanel>
						<StackPanel Grid.Column="2" Spacing="10">
							<TextBlock Text="Additional quantity"
									   Classes="textBoxLabel"
									   HorizontalAlignment="Stretch" />
							<NumericUpDown Value="{Binding Quantity}"
										   Watermark="Enter additional quantity"
										   FormatString="0"
										   Minimum="0" />
						</StackPanel>
					</Grid>


					<!-- Rent Offer Fields -->
					<StackPanel Spacing="10" IsVisible="{Binding !IsSaleOffer}">
						<TextBlock Text="Rental price per day"
								   Classes="textBoxLabel" />
						<NumericUpDown Value="{Binding PricePerDay}"
									   FormatString="0.00"
									   Minimum="1"
									   Watermark="Enter price per one day of rental period" />

						<StackPanel IsVisible="{Binding !IsEditMode}" Spacing="10">
							<TextBlock Text="Max Rental Days"
									   Classes="textBoxLabel" />
							<NumericUpDown Value="{Binding RentalDays}"
										   FormatString="0"
										   Watermark="Enter desired maximum days of rental period (360 max)"
										   Minimum="1" />

						</StackPanel>

						<Grid ColumnDefinitions="31*, 2*, 69*" IsVisible="{Binding IsEditMode}">
							<StackPanel Grid.Column="0" Spacing="10">
								<TextBlock Text="Current days"
										   Classes="textBoxLabel"
										   HorizontalAlignment="Stretch" />
								<TextBox IsEnabled="False"
										 Text="{Binding MaxRentalDays}"
										 TextWrapping="Wrap" />
							</StackPanel>

							<StackPanel Grid.Column="2" Spacing="10">
								<TextBlock Text="Additional rental days"
										   Classes="textBoxLabel"
										   HorizontalAlignment="Stretch" />
								<NumericUpDown Value="{Binding RentalDays}"
											   Watermark="Enter additional quantity"
											   FormatString="0"
											   Minimum="0" />
							</StackPanel>
						</Grid>


					</StackPanel>

					<!-- Sale Offer Fields -->
					<StackPanel Spacing="10"
								IsVisible="{Binding IsSaleOffer}">
						<TextBlock Text="Unit price"
								   Classes="textBoxLabel" />
						<NumericUpDown Value="{Binding PricePerItem}"
									   FormatString="0.00"
									   Minimum="1"
									   Watermark="Enter price per one item" />
					</StackPanel>

					<!-- Deliveries -->
					<StackPanel Spacing="10">

						<!-- Parcel lockers -->
						<TextBlock Text="Parcel Lockers:"
								   FontWeight="700" />
						<ItemsControl ItemsSource="{Binding ParcelLockerGroups}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<StackPanel>
										<TextBlock Text="{Binding Carrier}" />
										<ItemsControl ItemsSource="{Binding Options}">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:CompileBindings="false">
													<Grid ColumnDefinitions="auto,*,auto">
														<StackPanel Orientation="Horizontal">
															<RadioButton IsThreeState="True"
																		 GroupName="{Binding Carrier}"
																		 IsChecked="{Binding IsSelected, Mode=TwoWay}" />
															<TextBlock Text="{Binding Name}"
																	   VerticalAlignment="Center" />
														</StackPanel>
														<TextBlock Grid.Column="2"
																   VerticalAlignment="Center"
																   Text="{Binding PriceAndCurrency}" />
													</Grid>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<!-- Courier -->
						<TextBlock Text="Courier:"
								   FontWeight="700" />
						<ItemsControl ItemsSource="{Binding CourierDeliveries}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<StackPanel Spacing="10">
										<Grid ColumnDefinitions="auto,*,auto">
											<StackPanel Orientation="Horizontal">
												<CheckBox x:CompileBindings="false"
														  IsThreeState="False"
														  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
												<TextBlock Text="{Binding Name}"
														   VerticalAlignment="Center" />
											</StackPanel>
											<TextBlock Grid.Column="2"
													   Text="{Binding PriceAndCurrency}"
													   VerticalAlignment="Center" />
										</Grid>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<!-- Pickup point -->
						<TextBlock Text="Pickup Point:"
								   FontWeight="700" />
						<ItemsControl ItemsSource="{Binding PickupPointDeliveries}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<StackPanel>
										<Grid ColumnDefinitions="auto,*,auto">
											<StackPanel Orientation="Horizontal">
												<CheckBox x:CompileBindings="false"
														  IsThreeState="False"
														  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
												<TextBlock Text="{Binding Name}"
														   VerticalAlignment="Center" />
											</StackPanel>
											<TextBlock Grid.Column="2"
													   Text="{Binding PriceAndCurrency}"
													   VerticalAlignment="Center" />
										</Grid>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>

					<!-- Error -->
					<TextBlock
					Text="{Binding Error}"
					FontFamily="{DynamicResource RalewayBold}"
					Foreground="{DynamicResource ErrorBrush}"
					TextWrapping="Wrap" />

					<!-- Action Buttons -->
					<StackPanel Grid.Row="2"
								Orientation="Horizontal"
								HorizontalAlignment="Right"
								Spacing="8">
						<Button Content="Cancel"
								Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=dialogHost:DialogHost},
								Path=CloseDialogCommand}"
								CommandParameter="False" />
						<Button Content="Save"
								Command="{Binding SaveCommand}" />
					</StackPanel>
				</StackPanel>
			</Grid>
		</ScrollViewer>
	</Border>
</UserControl>
