<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:views="using:ByteBuy.UI.Views.Shared"
			 xmlns:vm="clr-namespace:ByteBuy.UI.ViewModels"
			 Background="Transparent"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ByteBuy.UI.Views.SaleOffersView"
			 x:DataType="vm:SaleOffersViewModel">

	<UserControl.Styles>
		<StyleInclude Source="../Styles/EmployeeStyles.axaml" />
	</UserControl.Styles>

	<Grid>
		<Grid RowDefinitions="50, auto, *,50">

			<Button
			Grid.Row="0"
			Grid.Column="1"
			Command="{Binding AddCommand}"
			VerticalAlignment="Top"
			HorizontalAlignment="Right">
				<StackPanel Orientation="Horizontal">
					<Image Source="{SvgImage /Assets/Images/regular/plus-solid-full.svg}"
						   Width="15" Height="15" />
				</StackPanel>
			</Button>

			<!--Filters-->

				<WrapPanel  Orientation="Horizontal" Grid.Row="1" ItemSpacing="10" Margin="0,15" LineSpacing="10">

					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Item" FontFamily="OpenSansBold" FontWeight="600"/>
						<TextBox Width="150" Text="{Binding Name}"/>
					</StackPanel>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Price From" FontFamily="OpenSansBold" FontWeight="600"/>
						<NumericUpDown Width="150" Value="{Binding PriceFrom}"/>
					</StackPanel>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Price To" FontFamily="OpenSansBold" FontWeight="600"/>
						<NumericUpDown Width="150" Value="{Binding PriceTo}"/>
					</StackPanel>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Quantity From" FontFamily="OpenSansBold" FontWeight="600"/>
						<NumericUpDown Width="150" Value="{Binding QuantityFrom}"/>
					</StackPanel>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Quantity To" FontFamily="OpenSansBold" FontWeight="600"/>
						<NumericUpDown Width="150" Value="{Binding QuantityTo}"/>
					</StackPanel>
					<Button Command="{Binding LoadDataCommand}" VerticalAlignment="Bottom">
						<StackPanel Orientation="Horizontal">
							<Image Margin="5,0"  Source="{SvgImage /Assets/Images/regular/filter-solid-full.svg}"
								   Height="15"
								   Width="15" />
							<TextBlock Text="Filter"/>
						</StackPanel>
					</Button>

					<Button Command="{Binding ClearFiltersCommand}" VerticalAlignment="Bottom">
						<StackPanel Orientation="Horizontal">
							<Image Margin="5,0" Source="{SvgImage /Assets/Images/regular/filter-circle-xmark-solid-full.svg}"
								   Height="15"
								   Width="15" />
							<TextBlock Text="Clear"/>
						</StackPanel>
					</Button>
				</WrapPanel>
			

			<!-- Fetched items count -->
			<StackPanel Grid.Row="2">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
					<Label Content="Records fetched:"
						   FontFamily="{DynamicResource RalewayMedium}"
						   Foreground="{DynamicResource TextPrimaryBrush}"
						   HorizontalAlignment="Right" />
					<Label Content="{Binding ItemsCount}"
						   FontFamily="{DynamicResource RalewayBold}"
						   Foreground="{DynamicResource TextPrimaryBrush}"
						   HorizontalAlignment="Right" />
				</StackPanel>

				<!-- Data Grid Containing All Items -->
				<DataGrid
				x:Name="ItemsGrid"
				ItemsSource="{Binding Items}"
				AutoGenerateColumns="False"
				SelectedItem="{Binding SelectedItem}"
				GridLinesVisibility="All"
				IsReadOnly="True"
				HeadersVisibility="All"
				CanUserSortColumns="True"
				CanUserResizeColumns="True"
				RowHeight="36">

					<DataGrid.Columns>
						<DataGridTextColumn Header="Nr." Binding="{Binding RowNumber}" Width="70" />
						<DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*" />
						<DataGridTextColumn Header="Quantity" Binding="{Binding QuantityAvailable}" Width="*" />
						<DataGridTextColumn Header="Unit Price" Binding="{Binding PriceAndCurrencyPerItem}" Width="*" />
						<DataGridTextColumn Header="Created By" Binding="{Binding CreatorEmail}" Width="*" />
						<DataGridTemplateColumn Header="Actions">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" x:CompileBindings="false">
										<Button
										Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
										CommandParameter="{Binding}"
										Margin="0,0,5,0">

											<Image Source="{SvgImage /Assets/Images/regular/edit.svg}"
												   Width="16" Height="16"/>
										</Button>

										<Button
										Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
										CommandParameter="{Binding}"
										FontSize="10">

											<Image Source="{SvgImage /Assets/Images/regular/delete.svg}"
												   Width="16" Height="16"/>
										</Button>
									</StackPanel>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
					</DataGrid.Columns>

				</DataGrid>

			</StackPanel>

			<StackPanel Grid.Row="3" HorizontalAlignment="Center" Orientation="Horizontal">
				<Button Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}">
					<Image Source="{SvgImage /Assets/Images/regular/arrow-left-solid-full.svg}"
						   Height="15"
						   Width="15" />
				</Button>
				<TextBlock
				Margin="5,0,5,0"
				FontSize="15"
				FontWeight="600"
				FontFamily="{DynamicResource RalewayMedium}"
				VerticalAlignment="Center"
				Foreground="{DynamicResource TextPrimaryBrush}">
					<Run Text="{Binding CurrentPage}"/>
					<Run Text="of"/>
					<Run Text="{Binding TotalPages}"/>
				</TextBlock>
				<Button Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}">
					<Image Source="{SvgImage /Assets/Images/regular/arrow-right-solid-full.svg}"
						   Height="15"
						   Width="15" />
				</Button>
			</StackPanel>

		</Grid>
		<views:AlertView
		DataContext="{Binding Alert}"
		IsVisible="{Binding IsVisible}"
		HorizontalAlignment="Right"
		VerticalAlignment="Bottom"
		Height="70"
		Width="400"
		Margin="0,20,20,40"
		ZIndex="10" />
	</Grid>
</UserControl>
