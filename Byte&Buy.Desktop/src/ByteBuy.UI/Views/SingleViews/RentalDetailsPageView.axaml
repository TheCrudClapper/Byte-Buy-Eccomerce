<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:ByteBuy.UI.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ByteBuy.UI.Views.RentalDetailsPageView"
			 x:DataType="vm:RentalDetailsPageViewModel">

	<UserControl.Styles>
		<StyleInclude Source="../../Styles/EmployeeStyles.axaml" />
		<StyleInclude Source="../../Styles/OrderRentalStyles.axaml" />
	</UserControl.Styles>

	<ScrollViewer>
		<Grid RowDefinitions="70,350">
			<TextBlock Grid.Row="0" Grid.Column="0" Classes="pageTitle" Text="Rental Details"/>

			<Border Grid.Row="1" Classes="sectionBorder" Padding="20" MaxHeight="360">
				<Grid RowDefinitions="30, 1, 20, 20, 170, 1, 20, 1"  ColumnDefinitions="*, *" >

					<!--Order Status-->
					<StackPanel Orientation="Horizontal" Grid.Column="0">
						<Image Margin="0,0,5,0"
							   Height="25"
							   Width="25">
							<Image.Source>
								<SvgImage Source="{Binding RentalIcon}" />
							</Image.Source>
						</Image>
						<TextBlock Text="{Binding RentalStatusText}" Classes="status" />
					</StackPanel>

					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
						<TextBlock Classes="status"  Text="Created"/>
						<TextBlock Classes="status">
							<Run Text=" ("/>
							<Run Text="{Binding DateCreated}"/>
							<Run Text=" )"/>
						</TextBlock>
					</StackPanel>

					<!--spacer-->
					<Border Grid.Row="1"
							Margin="0,10,0,10"
							Opacity="0.2"
							Grid.ColumnSpan="3"
							Background="{DynamicResource PrimaryAccentBrush}" Height="1"/>

					<Grid Grid.Row="2" Grid.ColumnSpan="2" RowDefinitions="20, 20" ColumnDefinitions="*,*">
						<StackPanel Orientation="Horizontal">
							<TextBlock Classes="standardText" Text="Lended for "/>
							<TextBlock Classes="standardText bold" Text="{Binding BorrowerName}"/>
							<TextBlock Classes="standardText bold">
								<Run Text=" ( "/>
								<Run Text="{Binding BorrowerEmail}"/>
								<Run Text=" )"/>
							</TextBlock>
						</StackPanel>

						<StackPanel Orientation="Horizontal" Grid.Row="1">
							<TextBlock Classes="standardText" Text="Lended from "/>
							<TextBlock Classes="standardText bold" Text="{Binding StartingRentalDate}"/>
							<TextBlock Classes="standardText" Text=" to "/>
							<TextBlock Classes="standardText bold" Text="{Binding EndingRentalDate}"/>
						</StackPanel>

						<TextBlock HorizontalAlignment="Right" Classes="standardText bold" Grid.Column="1" Grid.Row="1">
							<Run Text="("/>
							<Run Text="{Binding RentalDays}"/>
							<Run Text=" days/s period)"/>
						</TextBlock>
					</Grid>

					<Border Grid.Row="4" Height="140" Classes="lineBorder" Grid.ColumnSpan="2"  Padding="15" >
						<Grid RowDefinitions="50*, 50*" ColumnDefinitions="120, *">

							<Image
							Grid.RowSpan="2"
							Width="100"
							Height="100"
							Stretch="UniformToFill"
							Source="{Binding ImageThumbnail.Preview}" />

							<TextBlock
							Grid.Column="1"
							Grid.Row="0"
							Classes="standardText bold"
							VerticalAlignment="Bottom"
							Text="{Binding ItemName}" />

							<StackPanel Grid.Column="1"
										Grid.Row="1"
										Orientation="Horizontal">

								<TextBlock Classes="standardText" Text="Lended "/>
								<TextBlock Classes="standardText bold" Text="{Binding Quantity}"/>
								<TextBlock Classes="standardText" Text=" unit/s"/>
							</StackPanel >

						</Grid>
					</Border>

					<Border Grid.Row="5"
							Margin="0,10,0,10"
							Opacity="0.2"
							Grid.ColumnSpan="3"
							Background="{DynamicResource PrimaryAccentBrush}" Height="1"/>

					<TextBlock Text="Total Paid" Grid.Row="6" Classes="standardText bold"/>
					<TextBlock HorizontalAlignment="Right"
							   Text="{Binding TotalPricePaid.Display}"
							   Grid.Column="1"
							   Grid.Row="6"
							   Classes="standardText bold"/>

					<Border Grid.Row="7"
							Margin="0,10,0,10"
							Opacity="0.2"
							Grid.ColumnSpan="3"
							Background="{DynamicResource PrimaryAccentBrush}" Height="1"/>
				</Grid>
			</Border>
		</Grid>
	</ScrollViewer>
</UserControl>
