<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:views="using:ByteBuy.UI.Views.Shared"
			 xmlns:vm="clr-namespace:ByteBuy.UI.ViewModels"
			 Background="Transparent"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ByteBuy.UI.Views.ItemsPageView"
			 x:DataType="vm:ItemsPageViewModel">


	<UserControl.Styles>
		<StyleInclude Source="../Styles/EmployeeStyles.axaml" />
	</UserControl.Styles>

	<Grid>
		<Grid RowDefinitions="110,*,50">

			<Grid Grid.ColumnDefinitions="*,170" RowDefinitions="30,10,60,10"  Grid.Row="0" >
				<Button
				Grid.Row="0"

				Grid.Column="1"
				Command="{Binding AddCommand}"
				VerticalAlignment="Top"
				HorizontalAlignment="Right">
					<StackPanel Orientation="Horizontal">
						<Image Source="{SvgImage /Assets/Images/regular/plus-solid-full.svg}"
							   Width="15" Height="15" />
					</StackPanel>
				</Button>

				<StackPanel Margin="2,0" Grid.Column="0" Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
					<StackPanel VerticalAlignment="Center" Margin="0,0,5,0">
						<TextBlock Text="Item" FontFamily="OpenSansBold" FontWeight="600"/>
						<TextBox Width="150" Text="{Binding Name}"/>
					</StackPanel>
					<StackPanel VerticalAlignment="Center" Margin="0,0,5,0">
						<TextBlock Text="Quantity From" FontFamily="OpenSansBold" FontWeight="600"/>
						<NumericUpDown Width="150" Value="{Binding StockQuantityFrom}"/>
					</StackPanel>
					<StackPanel VerticalAlignment="Center" Margin="0,0,5,0">
						<TextBlock Text="Quantity To" FontFamily="OpenSansBold" FontWeight="600"/>
						<NumericUpDown Width="150" Value="{Binding StockQuantityTo}"/>
					</StackPanel>
				</StackPanel>

				<StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
					<Button Margin="5,0" Command="{Binding LoadDataCommand}">
						<StackPanel Orientation="Horizontal">
							<Image Margin="5,0"  Source="{SvgImage /Assets/Images/regular/filter-solid-full.svg}"
								   Height="15"
								   Width="15" />
							<TextBlock Text="Filter"/>
						</StackPanel>
					</Button>

					<Button Command="{Binding ClearFiltersCommand}">
						<StackPanel Orientation="Horizontal">
							<Image Margin="5,0" Source="{SvgImage /Assets/Images/regular/filter-circle-xmark-solid-full.svg}"
								   Height="15"
								   Width="15" />
							<TextBlock Text="Clear"/>
						</StackPanel>
					</Button>
				</StackPanel>
			</Grid>

			<!-- Fetched items count -->
			<StackPanel Grid.Row="1">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
					<Label Content="Records fetched:"
						   FontFamily="{DynamicResource RalewayMedium}"
						   Foreground="{DynamicResource TextPrimaryBrush}"
						   HorizontalAlignment="Right" />
					<Label Content="{Binding ItemsCount}"
						   FontFamily="{DynamicResource RalewayBold}"
						   Foreground="{DynamicResource TextPrimaryBrush}"
						   HorizontalAlignment="Right" />
				</StackPanel>

				<!-- Data Grid Containing All Items -->
				<DataGrid
				x:Name="ItemsGrid"
				ItemsSource="{Binding Items}"
				AutoGenerateColumns="False"
				SelectedItem="{Binding SelectedItem}"
				GridLinesVisibility="All"
				IsReadOnly="True"
				HeadersVisibility="All"
				CanUserSortColumns="True"
				CanUserResizeColumns="True"
				RowHeight="36">

					<DataGrid.Columns>
						<DataGridTextColumn Header="Nr." Binding="{Binding RowNumber}" Width="70" />
						<DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="*" />
						<DataGridTextColumn Header="Condition" Binding="{Binding ConditionName}" Width="*" />
						<DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*" />
						<DataGridTextColumn Header="Stock Quantity" Binding="{Binding StockQuantity}" Width="*" />
						<DataGridTextColumn Header="Images Count" Binding="{Binding ImagesCount}" Width="*" />
						<DataGridTemplateColumn Header="Actions" MinWidth="130">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" x:CompileBindings="false">
										<Button
										Command="{Binding DataContext.PublishCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
										CommandParameter="{Binding}"
										FontSize="10"
										Margin="0,0,5,0">

											<Image Source="{SvgImage /Assets/Images/regular/upload-solid-full.svg}"
												   Width="16" Height="16"/>
										</Button>

										<Button
										Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
										CommandParameter="{Binding}"
										Margin="0,0,5,0">

											<Image Source="{SvgImage /Assets/Images/regular/edit.svg}"
												   Width="16" Height="16"/>
										</Button>

										<Button
										Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
										CommandParameter="{Binding}">

											<Image Source="{SvgImage /Assets/Images/regular/delete.svg}"
												   Width="16" Height="16"/>
										</Button>
									</StackPanel>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
					</DataGrid.Columns>

				</DataGrid>

			</StackPanel>


			<StackPanel Grid.Row="3" HorizontalAlignment="Center" Orientation="Horizontal">
				<Button Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}">
					<Image Source="{SvgImage /Assets/Images/regular/arrow-left-solid-full.svg}"
						   Height="15"
						   Width="15" />
				</Button>
				<TextBlock
				Margin="5,0,5,0"
				FontSize="15"
				FontWeight="600"
				FontFamily="{DynamicResource RalewayMedium}"
				VerticalAlignment="Center"
				Foreground="{DynamicResource TextPrimaryBrush}">
					<Run Text="{Binding CurrentPage}"/>
					<Run Text="of"/>
					<Run Text="{Binding TotalPages}"/>
				</TextBlock>
				<Button Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}">
					<Image Source="{SvgImage /Assets/Images/regular/arrow-right-solid-full.svg}"
						   Height="15"
						   Width="15" />
				</Button>
			</StackPanel>

		</Grid>
		<views:AlertView
		DataContext="{Binding Alert}"
		IsVisible="{Binding IsVisible}"
		HorizontalAlignment="Right"
		VerticalAlignment="Bottom"
		Height="70"
		Width="400"
		Margin="0,20,20,40"
		ZIndex="10" />
	</Grid>
</UserControl>
