<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ByteBuy.UI.ViewModels"
             xmlns:shared="clr-namespace:ByteBuy.UI.Views.Shared"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="ByteBuy.UI.Views.CompanyInfoPageView"
             x:DataType="vm:CompanyInfoPageViewModel">
       <UserControl.Styles>
        <StyleInclude Source="../Styles/EmployeeStyles.axaml" />
    </UserControl.Styles>

    <Grid>
        <Grid RowDefinitions="50,*"
              ColumnDefinitions="25*, 5*, 70*">
            <Label Grid.Row="0" Grid.Column="0" Classes="pageTitle" Content="Company Details" />

            <!-- Profile Picture Section -->
            <Border Grid.Row="1"
                    Height="250"
                    Background="{DynamicResource BackgroundLightBrush}"
                    VerticalAlignment="Top"
                    Padding="20"
                    Grid.Column="0"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    CornerRadius="10">
                <StackPanel>
                    <Border Background="{DynamicResource ButtonGradient}"
                            CornerRadius="10"
                            BorderBrush="Black"
                            BorderThickness="1">
                        <Image Source="{SvgImage /Assets/Images/regular/laptop-code-solid-full.svg}"
                               Height="150"
                               Width="150" />
                    </Border>

                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="10">
                        <Button>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{SvgImage /Assets/Images/regular/plus-solid-full.svg}"
                                       Height="15"
                                       Width="15" />
                                <Label Content="Add Picture" />
                            </StackPanel>

                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Padding="20"
                    Background="{DynamicResource BackgroundLightBrush}"
                    Grid.Column="2"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    CornerRadius="10">
                <ScrollViewer Padding="0,0,20,0">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,20,*" RowDefinitions="40,70,70">
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                <Image VerticalAlignment="Center"
                                       Margin="0,0,0,5"
                                       Source="{SvgImage /Assets/Images/regular/square-solid-full-primary.svg}"
                                       Height="10"
                                       Width="10" />
                                <Label Content="General Info"
                                       Classes="sectionLabel" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <Label Content="Company Name" Classes="textBoxLabel" />
                                <TextBox Text="{Binding CompanyName}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <Label Content="TIN (Taxpayer Identification Number)" Classes="textBoxLabel" />
                                <TextBox Text="{Binding Tin}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <Label Content="Email" Classes="textBoxLabel" />
                                <TextBox Text="{Binding Email}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <Label Content="Phone Number" Classes="textBoxLabel" />
                                <TextBox Text="{Binding PhoneNumber}"/>
                            </StackPanel>

                        </Grid>

                        <Grid ColumnDefinitions="*,20,*" RowDefinitions="40,70,70,70">
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                <Image VerticalAlignment="Center"
                                       Margin="0,0,0,5"
                                       Source="{SvgImage /Assets/Images/regular/square-solid-full-primary.svg}"
                                       Height="10"
                                       Width="10" />
                                <Label Content="Address Info"
                                       Classes="sectionLabel" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <Label Content="City" Classes="textBoxLabel" />
                                <TextBox Text="{Binding City}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <Label Content="Street" Classes="textBoxLabel" />
                                <TextBox Text="{Binding Street}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <Label Content="House Number" Classes="textBoxLabel" />
                                <TextBox Text="{Binding HouseNumber}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <Label Content="Flat Number" Classes="textBoxLabel" />
                                <TextBox Text="{Binding FlatNumber}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <Label Content="Postal Code" Classes="textBoxLabel" />
                                <TextBox  Text="{Binding PostalCode}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="2">
                                <Label Content="Country" Classes="textBoxLabel" />
                                <TextBox Text="{Binding Country}" />
                            </StackPanel>
                            
                        </Grid>
                        <Grid ColumnDefinitions="*,20,*" RowDefinitions="40,70">
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal">
                                <Image VerticalAlignment="Center"
                                       Margin="0,0,0,5"
                                       Source="{SvgImage /Assets/Images/regular/square-solid-full-primary.svg}"
                                       Height="10"
                                       Width="10" />
                                <Label Content="Marketing"
                                       Classes="sectionLabel" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <Label Content="Slogan" Classes="textBoxLabel" />
                                <TextBox Text="{Binding Slogan}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                <Button
                                    Command="{Binding ClearCommand}"
                                    VerticalAlignment="Bottom"
                                    Margin="5,0"
                                    Content="Clear" />
                                <Button
                                    Command="{Binding SaveCommand}"
                                    VerticalAlignment="Bottom"
                                    Content="Save" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        <shared:AlertView
            DataContext="{Binding Alert}"
            IsVisible="{Binding IsVisible}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Height="70"
            Width="400"
            Margin="0,
            20,20,40"
            ZIndex="10" />
    </Grid>
</UserControl>
