<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ByteBuy.UI.ViewModels"
             xmlns:tabitems="clr-namespace:ByteBuy.UI.Views"
             Background="Transparent"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ByteBuy.UI.Views.AdministrationPageView"
             x:DataType="vm:AdministrationPageViewModel">


    <TabControl SelectedItem="{Binding SelectedTab}">
        <TabItem Header="Deliveries" Content="{Binding DeliveriesPageViewModel}"/>
        <TabItem Header="Categories" Content="{Binding CategoriesPageViewModel}"/>
        <TabItem Header="Condition" Content="{Binding ConditionsPageViewModel}"/>
        <TabItem Header="Countries" Content="{Binding CountriesPageViewModel}"/>

    </TabControl>
</UserControl>
