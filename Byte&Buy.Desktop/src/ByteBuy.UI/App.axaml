<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="ByteBuy.UI.App"
			 xmlns:ui="clr-namespace:ByteBuy.UI"
			 xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
			 RequestedThemeVariant="Default">

	<Application.DataTemplates>
		<ui:ViewLocator />
	</Application.DataTemplates>

	<Application.Styles>
		<FluentTheme />
		<StyleInclude Source="Styles/AppDefaultStyles.axaml" />
		<StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
		<dialogHostAvalonia:DialogHostStyles />
		<StyleInclude Source="Styles/MainWindowStyles.axaml"/>
		<StyleInclude Source="Styles/DialogHostStyleOverride.axaml"/>
		<StyleInclude Source="Styles/OrderRentalStyles.axaml"/>
	</Application.Styles>

	<Application.Resources>

		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<MergeResourceInclude Source="/Controls/TabControl.axaml"></MergeResourceInclude>
				<MergeResourceInclude Source="/Controls/TabItem.axaml"></MergeResourceInclude>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>



		<!--New Theme-->
		<Color x:Key="HoverAccent">#3b255a</Color>

		<Color x:Key="TextPrimary">#ffffff</Color>

		<Color x:Key="Background">#17182a</Color>

		<Color x:Key="CardBackground">#2d3059</Color>

		<Color x:Key="SecondaryAccent">#60118C</Color>

		<Color x:Key="PrimaryAccent">#8B5CF6</Color>

		<Color x:Key="GrayAccent">#26293f</Color>

		<Color x:Key="TextLight">#1E1E1E</Color>

		<!-- Colors -->
		<Color x:Key="BackgroundLight">#FFFFFF</Color>
		<Color x:Key="BackgroundDark">#121212</Color>
		<Color x:Key="BackgroundLightDarker">#ededed</Color>

		<Color x:Key="Primary">#60118C</Color>

		<Color x:Key="SecondaryLight">#8B5CF6</Color>
		<Color x:Key="SecondaryDark">#00FFC6</Color>


		<Color x:Key="TextDark">#E5E7EB</Color>

		<Color x:Key="TextMuted">#6B7280</Color>

		<Color x:Key="CardBgLight">#F9FAFB</Color>
		<Color x:Key="CardBgDark">#181226</Color>

		<Color x:Key="Hover">#7B2CBF</Color>

		<Color x:Key="Success">#22C55E</Color>
		<Color x:Key="Error">#EF4444</Color>

		<Color x:Key="GradientStartLight">#60118C</Color>

		<Color x:Key="GradientEndLight">#8B5CF6</Color>
		<Color x:Key="GradientEndDark">#00FFC6</Color>

		<!-- Brushes -->
		<SolidColorBrush x:Key="BackgroundLightBrush" Color="{StaticResource BackgroundLight}" />
		<SolidColorBrush x:Key="BackgroundLightDarkerBrush" Color="{StaticResource BackgroundLightDarker}" />
		<SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDark}" />
		<SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
		<SolidColorBrush x:Key="SecondaryLightBrush" Color="{StaticResource SecondaryLight}" />
		<SolidColorBrush x:Key="SecondaryDarkBrush" Color="{StaticResource SecondaryDark}" />
		<SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDark}" />
		<SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
		<SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}" />


		<!--New Brushes-->
		<SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
		<SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
		<SolidColorBrush x:Key="HoverAccentBrush" Color="{StaticResource HoverAccent}"/>
		<SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
		<SolidColorBrush x:Key="SecondaryAccentBrush" Color="{StaticResource SecondaryAccent}"/>
		<SolidColorBrush x:Key="PrimaryAccentBrush" Color="{StaticResource PrimaryAccent}"/>
		<SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}" />
		<SolidColorBrush x:Key="GrayAccentBrush" Color="{StaticResource GrayAccent}"/>

		<LinearGradientBrush x:Key="ButtonGradient" StartPoint="0%, 100%" EndPoint="100%, 0%">
			<GradientStop Offset="0" Color="{DynamicResource Primary}"></GradientStop>
			<GradientStop Offset="1" Color="{DynamicResource SecondaryLight}"></GradientStop>
		</LinearGradientBrush>

		<!-- Fonts -->
		<FontFamily x:Key="SegoeUiThis">/Assets/Fonts/segoeuithibd.ttf#Segoe UI This</FontFamily>
		<FontFamily x:Key="SegoeUiThisBoldItalic">/Assets/Fonts/segoeuithisz.ttf#Segoe UI This</FontFamily>
		<FontFamily x:Key="SegoeUiThisBoldReqular">/Assets/Fonts/segoeuithis.ttf#Segoe UI This</FontFamily>

		<FontFamily x:Key="OpenSansBold">/Assets/Fonts/opensansbold.ttf#Open Sans</FontFamily>

		<FontFamily x:Key="OpenSansMedium">/Assets/Fonts/opensansmedium.ttf#Open Sans Medium</FontFamily>
		<FontFamily x:Key="RalewayBold">/Assets/Fonts/ralewaybold.ttf#Raleway</FontFamily>
		<FontFamily x:Key="RalewayMedium">/Assets/Fonts/ralewaymedium.ttf#Raleway Medium</FontFamily>

	</Application.Resources>
</Application>