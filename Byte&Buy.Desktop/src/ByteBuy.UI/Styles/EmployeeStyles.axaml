<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <ListBox SelectionMode="Multiple">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="10*, 80*, 10*">
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="1" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="users:read" />
                            <CheckBox Grid.Column="2" IsChecked="True" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox></ListBox>
            </ListBox>
        </Border>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    <Style Selector="Label.sectionLabel">
        <Setter Property="FontFamily" Value="{DynamicResource SegoeUiThis}"></Setter>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="700"/>
        <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
    </Style>

    <Style Selector="TextBox.textBox, ComboBox">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="600"/>
        <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
        <Setter Property="Width" Value="220"/>
    </Style>
    
   <Style Selector="ListBox">
       <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
       <Setter Property="BorderThickness" Value="0"/>
       <Setter Property="Padding" Value="5"/>
       <Setter Property="FontWeight" Value="600"/>
   </Style>
    
    <Style Selector="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
        <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Margin" Value="1"/>
    </Style>
    
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryLightBrush}"/>
    </Style>

    <Style Selector="ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryLightBrush}"/>
    </Style>
    
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
        <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
    </Style>
    
    <Style Selector="Border.sectionBorder">
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

</Styles>
