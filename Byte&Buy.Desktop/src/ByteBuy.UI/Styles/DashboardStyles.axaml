<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<Design.PreviewWith>
		<Border Padding="20">
			<!-- Add Controls for Previewer Here -->
		</Border>
	</Design.PreviewWith>

	<!-- Add Styles Here -->
	<Style Selector="TextBlock.standardText">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="FontFamily" Value="OpenSansMedium"/>
	</Style>

	<Style Selector="Border.card">
		<Setter Property="CornerRadius" Value="10"/>
		<Setter Property="Background" Value="{DynamicResource CardBackground}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="10"/>
	</Style>

	<Style Selector="TextBlock.cardStat">
		<Setter Property="FontSize" Value="20"/>
		<Setter Property="FontWeight" Value="600"/>
		<Setter Property="FontFamily" Value="OpenSansBold"/>
	</Style>

	<Style Selector="TextBlock.cardSubText">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="FontFamily" Value="OpenSansMedium"/>
	</Style>

	<Style Selector="Image.cardImage">
		<Setter Property="Height" Value="35"/>
		<Setter Property="Width" Value="35"/>
		<Setter Property="Stretch" Value="Uniform"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
	</Style>

	<Style Selector="Border.cardImageBorder">
		<Setter Property="Height" Value="55"/>
		<Setter Property="Width" Value="55"/>
		<Setter Property="BorderBrush" Value="{DynamicResource SecondaryAccentBrush}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Background" Value="{DynamicResource PrimaryAccentBrush}"/>
		<Setter Property="CornerRadius" Value="40"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
	</Style>


</Styles>
