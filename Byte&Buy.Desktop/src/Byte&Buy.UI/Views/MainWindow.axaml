<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:ByteBuy.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        Height="700" Width="1200"
        x:Class="ByteBuy.Desktop.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ByteBuy.Desktop">

    <Grid ColumnDefinitions="220, *">
        <Grid Column="0" Background="{DynamicResource SidebarGradient}">
            <StackPanel Margin="5,0">
                <Label
                    FontFamily="{DynamicResource SegoeUiThisBoldReqular}"
                    FontSize="20"
                    FontWeight="700"
                    Foreground="{DynamicResource TextLightBrush}"
                   >
                    Management Panel
                </Label>

                <Border
                    
                    HorizontalAlignment="Stretch"
                        BorderBrush="{DynamicResource TextLightBrush}"
                        CornerRadius="5"
                        BorderThickness="1"
                        Margin="0,0,0,10"/>
                
                <Button
                    Classes="menu">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{SvgImage /Assets/Images/regular/list-alt.svg}"
                               Width="20" Height="20" />
                        <Label Content="Dashboard"></Label>
                    </StackPanel>
                </Button>

                <Button
                    Classes="menu">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{SvgImage /Assets/Images/regular/vcard.svg}"
                               Width="20" Height="20" />
                        <Label Content="Employees"></Label>
                    </StackPanel>
                </Button>


                <Button
                    Classes="menu">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{SvgImage /Assets/Images/regular/vcard.svg}"
                               Width="20" Height="20" />
                        <Label Content="Orders"></Label>
                    </StackPanel>
                </Button>

                <Button
                    Classes="menu">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{SvgImage /Assets/Images/regular/vcard.svg}"
                               Width="20" Height="20" />
                        <Label Content="Documents"></Label>
                    </StackPanel>
                </Button>

                <Button
                    Classes="menu">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{SvgImage /Assets/Images/regular/vcard.svg}"
                               Width="20" Height="20" />
                        <Label Content="Employees"></Label>
                    </StackPanel>
                </Button>

            </StackPanel>
            <Grid RowDefinitions="*, 50">
                <Grid Row="1">
                    <Button
                        Margin="5,5"
                        Background="{DynamicResource ButtonGradient}">
                        <Image Source="{SvgImage /Assets/Images/regular/soccer-ball.svg}"
                               Height="20" Width="20" />
                    </Button>
                </Grid>
            </Grid>
        </Grid>
        <Grid Column="1" Background="{DynamicResource BackgroundLight}">
        </Grid>
    </Grid>

</Window>